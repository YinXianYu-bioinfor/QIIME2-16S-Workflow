# QIIME2 binary artifacts (excluding .qzv visualizations)
*.qza

# Raw & intermediate sequencing data
*.fq
*.fq.gz
seq/
trimmed/

# FastQC & MultiQC intermediate reports
fastqc_*/
multiqc_report*.*
multiqc_report*_data/

# Cutadapt logs (per-sample)
cutadapt_logs/
results/cutadapt_logs/

# Core metrics intermediate files
results/core-metrics-results/

# Generated manifest file
manifest

# Pipeline runtime logs
logs/

# Generated QIIME2 visualizations (located in results/)
results/alpha-rarefaction.qzv
results/taxa-bar-plots.qzv
results/export/

# Common pipeline output
nohup.out
temp/

# But track example files explicitly (override above patterns)
!/examples/manifest
!/examples/logs/
